diff --git a/src/__tests__/dag-status.spec.ts b/src/__tests__/dag-status.spec.ts
index e6bf912..4b7c22f 100644
--- a/src/__tests__/dag-status.spec.ts
+++ b/src/__tests__/dag-status.spec.ts
@@ -1,6 +1,7 @@
 import { describe, test, expect } from 'bun:test';
 import { projectStatusFromGraph } from '../dag/status.js';
 import { buildGraph } from '../dag/builder.js';
+import type { AgentResult } from '../types.js';
 import type { PipelineGraph, DagNode } from '../dag/types.js';
 
 function setNodeState(graph: PipelineGraph, nodeId: string, state: DagNode['state']) {
@@ -9,6 +10,29 @@ function setNodeState(graph: PipelineGraph, nodeId: string, state: DagNode['stat
   node.state = state;
 }
 
+function setNodeResult(graph: PipelineGraph, nodeId: string, result: AgentResult) {
+  const node = graph.nodes.get(nodeId);
+  if (!node) throw new Error(`Node ${nodeId} not found`);
+  node.result = result;
+}
+
+function completedResult(prUrl: string | null): AgentResult {
+  return {
+    status: 'completed',
+    summary: prUrl ? 'PR created' : 'Close completed without a PR URL',
+    artifacts: {
+      commit: null,
+      filesChanged: [],
+      testsPassed: null,
+      screenshotUrls: [],
+      evidenceMarkers: [],
+      prUrl,
+      prNumber: prUrl ? 42 : null,
+    },
+    error: null,
+  };
+}
+
 describe('projectStatusFromGraph', () => {
   test('returns active when no nodes are running and first node is pending', () => {
     const graph = buildGraph('standard', 2);
@@ -66,6 +90,7 @@ describe('projectStatusFromGraph', () => {
     setNodeState(graph, 'verify_0', 'completed');
     setNodeState(graph, 'review_0', 'completed');
     setNodeState(graph, 'close', 'completed');
+    setNodeResult(graph, 'close', completedResult('https://github.com/org/repo/pull/42'));
     // skip unused revision nodes
     for (let c = 1; c <= 2; c++) {
       setNodeState(graph, `implement_${c}`, 'skipped');
@@ -75,6 +100,22 @@ describe('projectStatusFromGraph', () => {
     expect(projectStatusFromGraph(graph)).toBe('pr-opened');
   });
 
+  test('returns closing when close completed without a PR URL', () => {
+    const graph = buildGraph('standard', 2);
+    setNodeState(graph, 'implement_0', 'completed');
+    setNodeState(graph, 'verify_0', 'completed');
+    setNodeState(graph, 'review_0', 'completed');
+    setNodeState(graph, 'close', 'completed');
+    setNodeResult(graph, 'close', completedResult(null));
+    // skip unused revision nodes
+    for (let c = 1; c <= 2; c++) {
+      setNodeState(graph, `implement_${c}`, 'skipped');
+      setNodeState(graph, `verify_${c}`, 'skipped');
+      setNodeState(graph, `review_${c}`, 'skipped');
+    }
+    expect(projectStatusFromGraph(graph)).toBe('closing');
+  });
+
   test('returns merged when all nodes are completed/skipped', () => {
     const graph = buildGraph('standard', 2);
     setNodeState(graph, 'scout_0', 'completed');
