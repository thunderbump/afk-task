 }
+
+async function loadRuntimeModule(path: string): Promise<CaseAgentRuntime> {
+  const mod = await import(pathToFileURL(resolve(path)).href);
+  const exported = typeof mod.createCaseRuntime === 'function' ? mod.createCaseRuntime : mod.default;
+  const runtime = typeof exported === 'function' ? await exported() : exported;
+
+  if (!isCaseAgentRuntime(runtime)) {
+    throw new Error(
+      `Runtime module must export createCaseRuntime() or a default factory/object compatible with CaseAgentRuntime: ${path}`,
+    );
+  }
+
+  return runtime;
+}
+
+function isCaseAgentRuntime(value: unknown): value is CaseAgentRuntime {
+  if (typeof value !== 'object' || value === null) return false;
+  const runtime = value as Partial<Record<keyof CaseAgentRuntime, unknown>>;
+  return (
+    typeof runtime.spawn === 'function' &&
+    typeof runtime.createTools === 'function' &&
+    typeof runtime.abort === 'function'
+  );
+}
