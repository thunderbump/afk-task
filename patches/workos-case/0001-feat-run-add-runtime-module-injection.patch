+import { afterEach, describe, expect, it } from 'bun:test';
+import { mkdtemp, mkdir, readFile, rm, writeFile } from 'node:fs/promises';
+import { tmpdir } from 'node:os';
+import { join } from 'node:path';
+
+const expectedSpawns = ['scout', 'implementer', 'verifier', 'reviewer', 'closer', 'retrospective', ''].join('\n');
+const tempRoots: string[] = [];
+
+afterEach(async () => {
+  await Promise.all(tempRoots.splice(0).map((dir) => rm(dir, { recursive: true, force: true })));
+});
+
+describe('run --runtime-module', () => {
+  it('runs a task through a named createCaseRuntime export without Pi', async () => {
+    await expect(
+      runTaskWithRuntimeModule('export function createCaseRuntime() { return createRuntime(); }'),
+    ).resolves.toBe(expectedSpawns);
+  });
+
+  it('runs a task through a default runtime factory without Pi', async () => {
+    await expect(
+      runTaskWithRuntimeModule('export default function createDefaultRuntime() { return createRuntime(); }'),
+    ).resolves.toBe(expectedSpawns);
+  });
+
+  it('runs a task through a default runtime object without Pi', async () => {
+    await expect(runTaskWithRuntimeModule('export default createRuntime();')).resolves.toBe(expectedSpawns);
+  });
+});
+
+async function runTaskWithRuntimeModule(exportSource: string): Promise<string> {
+  const root = await mkdtemp(join(tmpdir(), 'case-runtime-module-'));
+  tempRoots.push(root);
+
+  const caseDataDir = join(root, 'case-data');
+  const targetRepo = join(root, 'target-repo');
+  const taskDir = join(targetRepo, '.case', 'tasks', 'active');
+  const taskJsonPath = join(taskDir, 'fixture-1.task.json');
+  const taskMdPath = join(taskDir, 'fixture-1.md');
+  const runtimeLogPath = join(root, 'runtime-spawns.txt');
+  const runtimeModulePath = join(root, 'fake-runtime.ts');
+
+  await mkdir(caseDataDir, { recursive: true });
+  await mkdir(taskDir, { recursive: true });
+  await writeFile(join(targetRepo, 'README.md'), '# fixture\n');
+  await writeFile(
+    join(caseDataDir, 'config.json'),
+    JSON.stringify({ version: 1, projects: './projects.json' }, null, 2) + '\n',
+  );
+  await writeFile(
+    join(caseDataDir, 'projects.json'),
+    JSON.stringify(
+      {
+        repos: [
+          {
+            name: 'fixture',
+            evidenceStrategy: 'test-output',
+            path: targetRepo,
+            remote: 'https://example.test/fixture.git',
+            description: 'runtime module fixture',
+            language: 'TypeScript',
+            packageManager: 'bun',
+            commands: { test: 'bun test' },
+          },
+        ],
+      },
+      null,
+      2,
+    ) + '\n',
+  );
+  await writeFile(
+    taskJsonPath,
+    JSON.stringify(
+      {
+        id: 'fixture-1',
+        status: 'active',
+        created: '2026-06-13T00:00:00Z',
+        repo: 'fixture',
+        issue: 'Complete through fake runtime',
+        issueType: 'freeform',
+        agents: {},
+        tested: false,
+        manualTested: false,
+        prUrl: null,
+        prNumber: null,
+      },
+      null,
+      2,
+    ) + '\n',
+  );
+  await writeFile(taskMdPath, '# Complete through fake runtime\n');
+  await writeFile(runtimeModulePath, runtimeModuleSource(exportSource));
+
+  const proc = Bun.spawn(
+    [
+      'bun',
+      'src/index.ts',
+      'run',
+      '--task',
+      taskJsonPath,
+      '--mode',
+      'unattended',
+      '--runtime-module',
+      runtimeModulePath,
+    ],
+    {
+      cwd: process.cwd(),
+      env: {
+        ...process.env,
+        CASE_DATA_DIR: caseDataDir,
+        CASE_PACKAGE_ROOT: process.cwd(),
+        CASE_MODEL_OVERRIDE: 'missing-test-model',
+        CASE_SCOUT_TIMEOUT_MS: '1000',
+        HOME: join(root, 'home'),
+        RUNTIME_LOG_PATH: runtimeLogPath,
+        NO_COLOR: '1',
+      },
+      stdout: 'pipe',
+      stderr: 'pipe',
+    },
+  );
+  const timer = setTimeout(() => proc.kill(), 20_000);
+  const [stdout, stderr, exitCode] = await Promise.all([
+    new Response(proc.stdout).text(),
+    new Response(proc.stderr).text(),
+    proc.exited,
+  ]);
+  clearTimeout(timer);
+
+  expect({ exitCode, stdout, stderr }).toMatchObject({ exitCode: 0 });
+  return readFile(runtimeLogPath, 'utf-8');
+}
+
+function runtimeModuleSource(exportSource: string): string {
+  return `
+import { appendFileSync } from 'node:fs';
+
+const artifacts = {
+  commit: 'fake-runtime',
+  filesChanged: [],
+  testsPassed: true,
+  screenshotUrls: [],
+  evidenceMarkers: [],
+  prUrl: null,
+  prNumber: null,
+};
+
+function agentResult(agentName) {
+  const result = {
+    status: 'completed',
+    summary: agentName + ' completed through fake runtime',
+    artifacts,
+    error: null,
+  };
+
+  if (agentName === 'scout') {
+    result.findings = {
+      relevantFiles: [],
+      patterns: [],
+      constraints: [],
+    };
+  }
+
+  return result;
+}
+
+function createRuntime() {
+  return {
+    async spawn(options) {
+      appendFileSync(process.env.RUNTIME_LOG_PATH, options.agentName + '\\n');
+      const result = agentResult(options.agentName);
+      return {
+        raw: '<<<AGENT_RESULT\\n' + JSON.stringify({ result, scoutFindings: result.findings }) + '\\nAGENT_RESULT>>>',
+        result,
+        durationMs: 1,
+      };
+    },
+    createTools() {
+      return [];
+    },
+    abort() {},
+  };
+}
+
+${exportSource}
+`;
+}
