diff --git a/src/__tests__/commands.spec.ts b/src/__tests__/commands.spec.ts
index 5bab0f8..38f63b9 100644
--- a/src/__tests__/commands.spec.ts
+++ b/src/__tests__/commands.spec.ts
@@ -259,6 +259,48 @@ describe('mark-tested handler', () => {
   });
 });
 
+describe('evidence marker help', () => {
+  let outCapture: ReturnType<typeof captureStream>;
+  let errCapture: ReturnType<typeof captureStream>;
+
+  beforeEach(() => {
+    outCapture = captureStream(process.stdout);
+    errCapture = captureStream(process.stderr);
+  });
+
+  afterEach(() => {
+    outCapture.restore();
+    errCapture.restore();
+  });
+
+  it('prints mark-tested help without enforcing marker preconditions', async () => {
+    const { handler } = await import('../commands/mark-tested.js');
+    const code = await handler(['--help']);
+
+    expect(code).toBe(0);
+    expect(outCapture.lines.join('')).toContain('Usage: ca mark-tested');
+    expect(errCapture.lines.join('')).toBe('');
+  });
+
+  it('prints mark-manual-tested help without enforcing marker preconditions', async () => {
+    const { handler } = await import('../commands/mark-manual-tested.js');
+    const code = await handler(['--help']);
+
+    expect(code).toBe(0);
+    expect(outCapture.lines.join('')).toContain('Usage: ca mark-manual-tested');
+    expect(errCapture.lines.join('')).toBe('');
+  });
+
+  it('prints mark-reviewed help without enforcing marker preconditions', async () => {
+    const { handler } = await import('../commands/mark-reviewed.js');
+    const code = await handler(['--help']);
+
+    expect(code).toBe(0);
+    expect(outCapture.lines.join('')).toContain('Usage: ca mark-reviewed');
+    expect(errCapture.lines.join('')).toBe('');
+  });
+});
+
 describe('upload handler — preflight checks', () => {
   let errCapture: ReturnType<typeof captureStream>;
 
