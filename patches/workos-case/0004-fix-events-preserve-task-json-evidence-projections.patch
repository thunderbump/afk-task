     writeFileSync(this.taskJsonPath, JSON.stringify(task, null, 2) + '\n');
   }
 }
+
+function mergeProjection(task: TaskJson, projected: Partial<TaskJson>): TaskJson {
+  const merged: TaskJson = {
+    ...task,
+    ...projected,
+  };
+
+  merged.agents = mergeProjectedAgents(task.agents, projected.agents);
+
+  if (task.tested && projected.tested === false) {
+    merged.tested = true;
+  }
+
+  if (task.manualTested && projected.manualTested === false) {
+    merged.manualTested = true;
+  }
+
+  return merged;
+}
+
+function mergeProjectedAgents(
+  current: TaskJson['agents'],
+  projected: Partial<Record<AgentName, AgentPhase>> | undefined,
+): TaskJson['agents'] {
+  if (!projected) return current;
+
+  const merged: TaskJson['agents'] = { ...current };
+
+  for (const [agent, projectedPhase] of Object.entries(projected) as Array<[AgentName, AgentPhase | undefined]>) {
+    if (!projectedPhase) continue;
+
+    const currentPhase = current[agent];
+    if (
+      currentPhase?.status === 'completed' &&
+      currentPhase.completed &&
+      (projectedPhase.status !== 'completed' || !projectedPhase.completed)
+    ) {
+      merged[agent] = currentPhase;
+      continue;
+    }
+
+    merged[agent] = projectedPhase;
+  }
+
+  return merged;
+}
