+
     const taskJson = projectTaskJson(this.state);
     await this.taskStore.writeFromProjection(taskJson);

@@ -93,4 +95,19 @@ export class EventAppender {
       await this.taskStore.writeFromProjection(updatedTaskJson);
     }
   }
+
+  private async hydrateExistingMarkers(): Promise<void> {
+    if (!this.state) return;
+
+    for (const marker of ['tested', 'manual-tested', 'reviewed']) {
+      if (this.state.markers.has(marker)) continue;
+
+      try {
+        await access(resolve(this.caseRoot, '.case', this.taskSlug, marker));
+        this.state.markers.add(marker);
+      } catch {
+        // Missing marker files are expected during normal runs.
+      }
+    }
+  }
 }
