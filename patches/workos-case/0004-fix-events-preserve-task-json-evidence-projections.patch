@@ -0,0 +1,76 @@
+import { afterAll, beforeEach, describe, expect, test } from 'bun:test';
+import { mkdir, rm, writeFile } from 'node:fs/promises';
+import { resolve } from 'node:path';
+import { TaskStore } from '../state/task-store.js';
+import type { TaskJson } from '../types.js';
+
+const tmpDir = resolve(process.env.TMPDIR ?? '/tmp', `case-task-store-test-${Date.now()}`);
+let taskJsonPath: string;
+
+const BASE_TASK: TaskJson = {
+  id: 'task-1',
+  status: 'active',
+  created: '2026-01-01T00:00:00Z',
+  repo: 'test-repo',
+  agents: {},
+  tested: false,
+  manualTested: false,
+  prUrl: null,
+  prNumber: null,
+};
+
+beforeEach(async () => {
+  await mkdir(tmpDir, { recursive: true });
+  taskJsonPath = resolve(tmpDir, '.task.json');
+  await writeFile(taskJsonPath, JSON.stringify(BASE_TASK, null, 2) + '\n');
+});
+
+afterAll(async () => {
+  await rm(tmpDir, { recursive: true, force: true });
+});
+
+describe('TaskStore.writeFromProjection', () => {
+  test('does not regress existing evidence flags or completed agents from a stale projection', async () => {
+    await writeFile(
+      taskJsonPath,
+      JSON.stringify(
+        {
+          ...BASE_TASK,
+          agents: {
+            verifier: {
+              started: '2026-06-15T00:00:00.000Z',
+              completed: '2026-06-15T00:01:00.000Z',
+              status: 'completed',
+            },
+          },
+          tested: true,
+          manualTested: true,
+        },
+        null,
+        2,
+      ) + '\n',
+    );
+
+    const store = new TaskStore(taskJsonPath);
+    await store.writeFromProjection({
+      agents: {
+        verifier: {
+          started: '2026-06-15T00:00:00.000Z',
+          completed: null,
+          status: 'running',
+        },
+      },
+      tested: false,
+      manualTested: false,
+    });
+
+    const task = await store.read();
+    expect(task.tested).toBe(true);
+    expect(task.manualTested).toBe(true);
+    expect(task.agents.verifier).toEqual({
+      started: '2026-06-15T00:00:00.000Z',
+      completed: '2026-06-15T00:01:00.000Z',
+      status: 'completed',
+    });
+  });
+});
